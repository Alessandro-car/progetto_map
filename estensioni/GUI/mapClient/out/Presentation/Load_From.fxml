<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane
    maxHeight="-Infinity" maxWidth="-Infinity"
    minHeight="-Infinity" minWidth="-Infinity"
    prefHeight="509.0" prefWidth="692.0"
    style="-fx-background-color: linear-gradient(to bottom, #252535, #1A1A2A);"
    xmlns="http://javafx.com/javafx/11.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.Load_From_Controller">

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <children>
        <GridPane
            alignment="CENTER"
            layoutX="-3.0" layoutY="1.0"
            prefHeight="89.0" prefWidth="679.0"
            AnchorPane.leftAnchor="-3.0"
            AnchorPane.rightAnchor="16.0"
            AnchorPane.topAnchor="1.0">

            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="311.6" minWidth="10.0" prefWidth="205.2"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="308.8" minWidth="10.0" prefWidth="308.8"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="115.4" minWidth="10.0" prefWidth="115.4"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="74.4" minHeight="10.0" prefHeight="39.2" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="51.2" minHeight="10.0" prefHeight="51.2" vgrow="SOMETIMES"/>
            </rowConstraints>

            <children>
                <!-- fx:id aggiunto: il testo viene impostato dinamicamente in initialize() -->
                <Label
                    fx:id="tableNameLabel"
                    alignment="CENTER_LEFT" contentDisplay="CENTER"
                    prefHeight="15.0" prefWidth="278.0"
                    text="TABLE NAME"
                    textAlignment="LEFT"
                    textFill="#9090BB">
                    <font><Font name="Tahoma Bold" size="11.0"/></font>
                    <GridPane.margin><Insets left="30.0"/></GridPane.margin>
                </Label>

                <ComboBox
                    fx:id="tableNameValue"
                    editable="false"
                    promptText="select a table..."
                    prefHeight="30.0" prefWidth="308.0"
                    style="-fx-background-color: #2A2A3E;
                           -fx-text-fill: white;
                           -fx-prompt-text-fill: #ffffff;
                           -fx-border-color: #5C6BC0;
                           -fx-border-width: 1;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;"
                    GridPane.columnIndex="1"/>

                <Pane prefHeight="200.0" prefWidth="200.0"/>

                <Label
                    alignment="CENTER_LEFT" contentDisplay="CENTER"
                    prefHeight="15.0" prefWidth="278.0"
                    text="BRANCH" textAlignment="LEFT"
                    textFill="#9090BB"
                    GridPane.rowIndex="1">
                    <font><Font name="Tahoma Bold" size="11.0"/></font>
                    <GridPane.margin><Insets left="30.0"/></GridPane.margin>
                </Label>

                <TextField
                    fx:id="branchValue"
                    disable="true"
                    promptText="Insert branch"
                    style="-fx-background-color: #2A2A3E; 
                           -fx-text-fill: white; 
                           -fx-prompt-text-fill: #666688;
                           -fx-border-color: #5C6BC0;
                           -fx-border-width: 1;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="1"
                    prefHeight="30.0"/>

                <Button
                    fx:id="okButton"
                    disable="true"
                    mnemonicParsing="false"
                    onAction="#goAction"
                    text="OK!"
                    GridPane.columnIndex="2"
                    GridPane.rowIndex="1">
                    <font><Font name="Tahoma Bold" size="12.0"/></font>
                    <GridPane.margin><Insets left="15.0"/></GridPane.margin>
                </Button>
            </children>
        </GridPane>

       <TextArea
            fx:id="output"
            editable="false"
            focusTraversable="false"
            layoutX="20.0" layoutY="118.0"
            prefHeight="234.0" prefWidth="663.0"
            style="-fx-control-inner-background: #1A1A2A; 
                   -fx-text-fill: white; -fx-font-family: monospace;
                   -fx-viewport-background: #1A1A2A;
                   -fx-border-color: #3D5AFE;
                   -fx-border-width: 1;
                   -fx-border-radius: 6;
                   -fx-background-radius: 6;"
            AnchorPane.bottomAnchor="157.0"
            AnchorPane.leftAnchor="20.0"
            AnchorPane.rightAnchor="9.0"
            AnchorPane.topAnchor="118.0"/>

        <GridPane
            layoutX="17.0" layoutY="344.0"
            prefHeight="125.0" prefWidth="663.0"
            AnchorPane.bottomAnchor="19.0"
            AnchorPane.leftAnchor="17.0"
            AnchorPane.rightAnchor="12.0">

            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            </rowConstraints>

            <children>
                <AnchorPane>
                    <children>
                        <Button
                            fx:id="executionButton"
                            alignment="CENTER"
                            disable="true"
                            layoutY="27.0"
                            mnemonicParsing="false"
                            onAction="#execute"
                            prefHeight="34.0" prefWidth="198.0"
                            text="EXECUTE"
                            AnchorPane.bottomAnchor="28.2"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="24.8">
                            <font><Font name="Tahoma Bold" size="12.0"/></font>
                        </Button>
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1">
                    <children>
                        <Button
                            fx:id="newExecutionButton"
                            alignment="CENTER"
                            layoutX="-6.0" layoutY="27.0"
                            mnemonicParsing="false"
                            onAction="#newExecution"
                            prefHeight="34.0" prefWidth="198.0"
                            text="NEW EXECUTION"
                            AnchorPane.bottomAnchor="27.0"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="25.0">
                            <font><Font name="Tahoma Bold" size="12.0"/></font>
                        </Button>
                    </children>
                </AnchorPane>

                <AnchorPane prefHeight="130.0" prefWidth="225.0" GridPane.columnIndex="2">
                    <children>
                        <Button
                            fx:id="exitButton"
                            alignment="CENTER"
                            layoutY="27.0"
                            mnemonicParsing="false"
                            onAction="#exitFrame"
                            prefHeight="34.0" prefWidth="223.0"
                            text="EXIT"
                            AnchorPane.bottomAnchor="28.2"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="0.0">
                            <font><Font name="Tahoma Bold" size="12.0"/></font>
                        </Button>
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <children>
                        <Button
                            fx:id="menuButton"
                            layoutY="18.0"
                            mnemonicParsing="false"
                            onAction="#menu"
                            prefHeight="34.0" prefWidth="197.0"
                            text="MENU"
                            AnchorPane.bottomAnchor="19.0"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="25.0">
                            <font><Font name="Tahoma Bold" size="12.0"/></font>
                        </Button>
                    </children>
                </AnchorPane>
            </children>
        </GridPane>
    </children>
</AnchorPane>
